{
  "name": "eva-standalone",
  "version": "5.3.0",
  "description": "Localhost Electron shell for Eva AI Assistant.",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux AppImage",
    "dist:mac": "electron-builder --mac",
    "dist:all": "electron-builder --linux AppImage --mac"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1",
    "tmp": "^0.2.7"
  },
  "_comment": "Electron files stay in standalone/. electron-builder copies the parent web UI and bridge with extraResources into resources/app.",
  "build": {
    "appId": "com.appatalks.eva-standalone",
    "productName": "Eva Standalone",
    "files": [
      "package.json",
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "..",
        "to": "app",
        "filter": [
          "index.html",
          "README.md",
          "README-2.md",
          "config.example.json",
          "config.local.example.js",
          "mcp.json",
          "core/**",
          "tools/acp_bridge.py",
          "tools/browser_agent.py",
          "tools/desktop_agent.py",
          "tools/camera_sense.py",
          "tools/kusto_mcp.py",
          "tools/sqlite_memory.py",
          "tools/sqlite_mcp.py",
          "tools/eva_seed.kql",
          "!config.json",
          "!config.local.js",
          "!core/external/*.data",
          "!audio/**",
          "!tmp/**",
          "!*.log",
          "!**/*.log",
          "!**/.env*",
          "!standalone/**"
        ]
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity"
    }
  }
}
