# API keys and local config (NEVER commit these)
config.json
config.local.js

# Python
__pycache__/
*.pyc
*.pyo

# Runtime / temp data
*.data
core/external/*.data
audio/
*.wav
*.mp3

# OS files
.DS_Store
Thumbs.db

# Editors / IDE
*.swp
*.swo
*~
.vscode/
.idea/

# Logs and token caches
*.log
.azure/
msal_token_cache.json
token_cache.*

# Environment files
.env
.env.*

# Node (if npx runs locally)
node_modules/
standalone/node_modules/
standalone/dist/
standalone/out/
*.AppImage

# Local-only agent knowledge for the maintainer (never committed).
# Holds dev topology, cluster URLs, recurring commands, and agent playbooks
# that reference internal hosts. Keep all secrets and internal URLs here.
.github/agents/local/

# Eva-generated data artifacts. The file.download capability namespaces
# downloads under tmp/<session_id>/ so each session's artifacts are isolated
# and easy to clean up. Never commit the contents.
tmp/
tools/eval/results/
